# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.

# Anthropic API key — required. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# CHE MCP credentials — only needed once CHE MCP is released and enabled in
# mcp_config.json. Leave blank/unset while using Yahoo Finance MCP.
# CHE_API_KEY=
# CHE_JWT=

# RAG fallback (rag.py) — all optional; sensible defaults are built in. The
# embeddings, BM25, and reranker run locally (no API key). See rag.py for details.
# RAG_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# RAG_RERANK_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1   # "" or "none" disables reranking
# RAG_GUARD_MODEL=claude-haiku-4-5
# RAG_RELEVANCE_THRESHOLD=0.30   # dense cosine floor (0..1)
# RAG_RERANK_THRESHOLD=0.30      # reranker probability floor (0..1)
# RAG_DENSE_K=20                 # dense first-stage candidates
# RAG_SPARSE_K=20                # BM25 first-stage candidates
# RAG_FUSE_K=12                  # candidates kept after fusion, fed to the reranker
# RAG_TOP_K=4                    # final chunks returned
# RAG_INDEX_DIR=.rag_index
# RAG_HF_TOKEN=                  # only for a private RAG_EMBED_MODEL / RAG_RERANK_MODEL
